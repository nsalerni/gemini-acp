{
  "name": "@nsalerni/gemini-acp",
  "version": "0.1.7",
  "description": "A Node.js library for communicating with the Gemini CLI over the ACP (Agent Control Protocol) via stdio.",
  "license": "MIT",
  "author": "Nico Salerni",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors.js",
      "types": "./dist/errors.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./helpers": {
      "import": "./dist/helpers/index.js",
      "types": "./dist/helpers/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && npm run copy-files",
    "copy-files": "echo 'Build complete'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest",
    "test:run": "vitest run",
    "dev": "npm run typecheck && npm run test",
    "example:01": "tsx examples/01-basic.ts",
    "example:02": "tsx examples/02-with-image.ts",
    "example:03": "tsx examples/03-permission-handling.ts",
    "example:04": "tsx examples/04-session-resume.ts",
    "example:05": "tsx examples/05-warm-start.ts",
    "bench:warm-start": "tsx examples/bench-warm-start.ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "gemini",
    "cli",
    "acp",
    "agent",
    "control",
    "protocol",
    "ai",
    "multi-agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nsalerni/gemini-acp"
  },
  "bugs": {
    "url": "https://github.com/nsalerni/gemini-acp/issues"
  },
  "homepage": "https://github.com/nsalerni/gemini-acp#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "vitest": "^0.34.0"
  },
  "sideEffects": false
}
